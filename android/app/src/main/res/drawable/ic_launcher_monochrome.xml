<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome silhouette for Android 13+ themed icons.
    The system applies a single tint color; use white fills.
    Baffle with driver-shaped holes (evenOdd) + small center dots.
    Same safe-zone geometry as ic_launcher_foreground.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Baffle outline with driver holes punched through (evenOdd fill rule).
        Outer path = baffle rounded-rect (fills white).
        Inner paths = driver circles (punch transparent holes).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M 34,22
            L 74,22
            A 9,9 0 0,1 83,31
            L 83,77
            A 9,9 0 0,1 74,86
            L 34,86
            A 9,9 0 0,1 25,77
            L 25,31
            A 9,9 0 0,1 34,22 Z
            M 48,33 a 6,6 0 1,0 12,0 a 6,6 0 1,0 -12,0 Z
            M 45,54 a 9,9 0 1,0 18,0 a 9,9 0 1,0 -18,0 Z
            M 45,74 a 9,9 0 1,0 18,0 a 9,9 0 1,0 -18,0 Z" />

    <!-- Tweeter dome: small dot visible in the tweeter hole -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 52.2,33 a 1.8,1.8 0 1,0 3.6,0 a 1.8,1.8 0 1,0 -3.6,0 Z" />

    <!-- Woofer 1 dust cap -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 51.5,54 a 2.5,2.5 0 1,0 5,0 a 2.5,2.5 0 1,0 -5,0 Z" />

    <!-- Woofer 2 dust cap -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 51.5,74 a 2.5,2.5 0 1,0 5,0 a 2.5,2.5 0 1,0 -5,0 Z" />

</vector>
