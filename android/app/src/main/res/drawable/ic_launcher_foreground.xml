<?xml version="1.0" encoding="utf-8"?>
<!--
    Speaker icon — front-face view of a full-range speaker baffle.
    Canvas: 108×108dp. Safe zone: x/y 21–87 (central 66×66).

    Geometry:
      Baffle      : rounded-rect x=25,y=22 w=58 h=64 rx=9  → (25,22)–(83,86)
      Tweeter     : cx=54 cy=33   outer-r=6   cone-r=4.5  dome-r=1.8
      Woofer 1    : cx=54 cy=54   outer-r=9   cone-r=7    dustcap-r=2.5
      Woofer 2    : cx=54 cy=74   same as woofer 1

    Vertical gaps:
      tweeter-top(27) → baffle-top(22) = 5px inside baffle ✓
      tweeter-bottom(39) → woofer1-top(45) = 6px ✓
      woofer1-bottom(63) → woofer2-top(65) = 2px ✓
      woofer2-bottom(83) → baffle-bottom(86) = 3px ✓
      everything inside safe-zone(87) ✓

    Circle arc notation: M cx-r,cy  a r,r 0 1,0 2r,0  a r,r 0 1,0 -2r,0 Z
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Baffle (cabinet face) ── -->
    <path
        android:fillColor="#252830"
        android:strokeColor="#3A3F46"
        android:strokeWidth="0.75"
        android:pathData="
            M 34,22
            L 74,22
            A 9,9 0 0,1 83,31
            L 83,77
            A 9,9 0 0,1 74,86
            L 34,86
            A 9,9 0 0,1 25,77
            L 25,31
            A 9,9 0 0,1 34,22 Z" />

    <!-- ── Tweeter (cx=54, cy=33) ── -->
    <!-- Outer surround ring: r=6, cyan -->
    <path
        android:fillColor="#5EC8D8"
        android:pathData="M 48,33 a 6,6 0 1,0 12,0 a 6,6 0 1,0 -12,0 Z" />
    <!-- Cone: r=4.5, very dark -->
    <path
        android:fillColor="#1A1C20"
        android:strokeColor="#3A3F46"
        android:strokeWidth="0.5"
        android:pathData="M 49.5,33 a 4.5,4.5 0 1,0 9,0 a 4.5,4.5 0 1,0 -9,0 Z" />
    <!-- Center dome: r=1.8, medium grey -->
    <path
        android:fillColor="#3A3F46"
        android:pathData="M 52.2,33 a 1.8,1.8 0 1,0 3.6,0 a 1.8,1.8 0 1,0 -3.6,0 Z" />

    <!-- ── Woofer 1 (cx=54, cy=54) ── -->
    <!-- Outer surround ring: r=9, cyan -->
    <path
        android:fillColor="#5EC8D8"
        android:pathData="M 45,54 a 9,9 0 1,0 18,0 a 9,9 0 1,0 -18,0 Z" />
    <!-- Cone: r=7, very dark -->
    <path
        android:fillColor="#1A1C20"
        android:strokeColor="#3A3F46"
        android:strokeWidth="0.75"
        android:pathData="M 47,54 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z" />
    <!-- Cone mid-ring: r=4.5, subtle concentric detail -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#3A3F46"
        android:strokeWidth="0.75"
        android:pathData="M 49.5,54 a 4.5,4.5 0 1,0 9,0 a 4.5,4.5 0 1,0 -9,0 Z" />
    <!-- Dust cap: r=2.5, medium grey -->
    <path
        android:fillColor="#3A3F46"
        android:pathData="M 51.5,54 a 2.5,2.5 0 1,0 5,0 a 2.5,2.5 0 1,0 -5,0 Z" />

    <!-- ── Woofer 2 (cx=54, cy=74) ── -->
    <!-- Outer surround ring: r=9, cyan -->
    <path
        android:fillColor="#5EC8D8"
        android:pathData="M 45,74 a 9,9 0 1,0 18,0 a 9,9 0 1,0 -18,0 Z" />
    <!-- Cone: r=7, very dark -->
    <path
        android:fillColor="#1A1C20"
        android:strokeColor="#3A3F46"
        android:strokeWidth="0.75"
        android:pathData="M 47,74 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z" />
    <!-- Cone mid-ring: r=4.5, subtle concentric detail -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#3A3F46"
        android:strokeWidth="0.75"
        android:pathData="M 49.5,74 a 4.5,4.5 0 1,0 9,0 a 4.5,4.5 0 1,0 -9,0 Z" />
    <!-- Dust cap: r=2.5, medium grey -->
    <path
        android:fillColor="#3A3F46"
        android:pathData="M 51.5,74 a 2.5,2.5 0 1,0 5,0 a 2.5,2.5 0 1,0 -5,0 Z" />

</vector>
